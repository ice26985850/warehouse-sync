{
  "name": "multi-warehouse-sync",
  "version": "1.0.0",
  "description": "多仓库即时同步管理系统",
  "author": "SCPO5",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server/src/index.js",
    "build:client": "cd client && npm run build",
    "electron:dev": "electron .",
    "electron:build": "npm run build:client && electron-builder"
  },
  "build": {
    "appId": "com.scpo5.warehouse-sync",
    "productName": "多仓库同步管理系统",
    "directories": {
      "output": "release/electron"
    },
    "files": [
      "electron/**/*",
      "server/**/*",
      "server/node_modules/**/*",
      "client/dist/**/*",
      "!server/data/**"
    ],
    "extraResources": [
      {
        "from": "server",
        "to": "server",
        "filter": [
          "**/*",
          "!data/**"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/icon.png",
      "artifactName": "${productName}-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "多仓库同步管理系统"
    }
  },
  "devDependencies": {
    "electron": "^29.4.6",
    "electron-builder": "^24.13.3"
  }
}
